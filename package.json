{
  "name": "pymentor",
  "version": "1.0.0",
  "description": "Learn Python by Building Logic — an interactive, offline-capable Python tutor that runs on your machine",
  "license": "MIT",
  "author": "PyMentor",
  "repository": {
    "type": "git",
    "url": "https://github.com/mahesh-atx/Py_Mentor"
  },
  "homepage": "https://github.com/mahesh-atx/Py_Mentor#readme",
  "bugs": {
    "url": "https://github.com/mahesh-atx/Py_Mentor/issues"
  },
  "bin": {
    "pymentor": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "scripts/",
    "prisma/schema.sqlite.prisma",
    "prisma/migrations.sqlite/",
    "prisma/seed.ts",
    "prisma/notes/",
    "public/fonts/",
    "src/lib/db/",
    "src/lib/services/",
    "src/lib/ai/",
    "src/lib/xp-calculator.ts",
    "src/lib/rate-limit.ts",
    "src/lib/remark-alerts.ts",
    "NPM_DISTRIBUTION_PLAN.md"
  ],
  "keywords": [
    "python",
    "mentor",
    "learn",
    "tutorial",
    "offline",
    "programming",
    "education",
    "cli",
    "interactive",
    "pyodide"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:npm": "bash scripts/build.sh",
    "build:cloud": "bash scripts/build.sh --cloud",
    "prepare-dist": "node scripts/prepare-dist.js",
    "download-pyodide": "bash scripts/download-pyodide.sh",
    "start": "next start",
    "start:dist": "node dist/server/server.js",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:sqlite": "vitest run __tests__/sqlite-schema.test.ts __tests__/json-helper.test.ts __tests__/db-provider.test.ts __tests__/schema-sync.test.ts",
    "prepublishOnly": "npm run build:npm && npm test"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/typography": "^0.5.20",
    "@types/canvas-confetti": "^1.9.0",
    "@types/pg": "^8.20.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.42.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.23.0",
    "monaco-editor": "^0.55.1",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "pyodide": "^314.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.12.0",
    "recharts": "^3.9.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
