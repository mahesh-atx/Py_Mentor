# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
*.db
*.sqlite3
# SQLite database files (only .sqlite files at root or prisma level)
dev.sqlite
pymentor.db

# Pyodide — large WASM files, install via npm or download script
# The download-pyodide.sh script copies from node_modules/pyodide/ or downloads from CDN
# Uncomment the next line if you want to exclude Pyodide from git (saves ~13 MB)
# /public/pyodide/*.wasm
