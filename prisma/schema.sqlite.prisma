generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id              String            @id @default(uuid())
  name            String?
  email           String            @unique
  emailVerified   DateTime?
  image           String?
  passwordHash    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  aiChats         AIChat[]
  accounts        Account[]
  bookmarks       Bookmark[]
  notes           Note[]
  progress        Progress[]
  quizSubmissions QuizSubmission[]
  sessions        Session[]
  streaks         Streak[]
  submissions     Submission[]
  achievements    UserAchievement[]
  UserMemory      UserMemory[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Submission {
  id          String   @id @default(uuid())
  code        String
  language    String   @default("python")
  stdout      String?
  stderr      String?
  status      String
  score       Int?
  testResults String?
  aiReview    String?
  timeTaken   Int?
  createdAt   DateTime @default(now())
  userId      String
  exerciseId  String?
  projectId   String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Progress {
  id          String    @id @default(uuid())
  status      String    @default("not_started")
  score       Int?
  completedAt DateTime?
  timeSpent   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  lessonId    String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model QuizSubmission {
  id          String   @id @default(uuid())
  score       Int
  total       Int
  completedAt DateTime @default(now())
  userId      String
  quizId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quizId])
}

model Streak {
  id     String   @id @default(uuid())
  date   DateTime
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Achievement {
  id          String            @id @default(uuid())
  title       String            @unique
  description String
  icon        String
  color       String
  xpReward    Int               @default(100)
  condition   String
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(uuid())
  unlockedAt    DateTime    @default(now())
  userId        String
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

model Note {
  id        String   @id @default(uuid())
  content   String
  module    String?
  lessonRef String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id        String   @id @default(uuid())
  title     String
  type      String
  targetId  String
  module    String?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetId])
}

model AIChat {
  id        String          @id @default(uuid())
  title     String?
  context   String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AIChatMessage[]
}

model AIChatMessage {
  id        String   @id @default(uuid())
  role      String
  content   String
  code      String?
  createdAt DateTime @default(now())
  chatId    String
  chat      AIChat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

model UserMemory {
  id        String   @id @default(uuid())
  key       String
  value     String
  updatedAt DateTime @updatedAt
  userId    String
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model Roadmap {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  modules     Module[]
}

model Module {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roadmapId   String
  roadmap     Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  topics      Topic[]
}

model Topic {
  id          String     @id @default(uuid())
  title       String
  slug        String     @unique
  description String
  order       Int        @default(0)
  isPublished Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  moduleId    String
  exercises   Exercise[]
  lessons     Lesson[]
  projects    Project[]
  quizzes     Quiz[]
  module      Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Lesson {
  id          String   @id @default(uuid())
  title       String
  slug        String
  content     String
  objectives  String
  duration    Int
  xpReward    Int      @default(50)
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  topicId     String
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([topicId, slug])
}

model Exercise {
  id          String   @id @default(uuid())
  title       String
  slug        String
  description String
  starterCode String
  solution    String
  testCases   String
  hints       String
  difficulty  String
  xpReward    Int      @default(20)
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  topicId     String
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([topicId, slug])
}

model Quiz {
  id          String         @id @default(uuid())
  title       String
  slug        String
  description String
  xpReward    Int            @default(100)
  order       Int            @default(0)
  isPublished Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  topicId     String
  topic       Topic          @relation(fields: [topicId], references: [id], onDelete: Cascade)
  questions   QuizQuestion[]

  @@unique([topicId, slug])
}

model QuizQuestion {
  id            String @id @default(uuid())
  question      String
  options       String
  correctOption Int
  explanation   String
  order         Int    @default(0)
  quizId        String
  quiz          Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model Project {
  id           String   @id @default(uuid())
  title        String
  slug         String
  description  String
  requirements String
  milestones   String
  starterCode  String?
  solution     String?
  difficulty   String
  order        Int      @default(0)
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  topicId      String
  topic        Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([topicId, slug])
}
