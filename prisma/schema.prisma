// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ============================================================
// ENGINE 1: AUTHENTICATION
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  progress        Progress[]
  submissions     Submission[]
  achievements    UserAchievement[]
  quizSubmissions QuizSubmission[]
  notes           Note[]
  bookmarks       Bookmark[]
  aiChats         AIChat[]
  streaks         Streak[]
  sessions        Session[]
  accounts        Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// ENGINE 6: SUBMISSIONS
// ============================================================

model Submission {
  id         String   @id @default(cuid())
  code       String
  language   String   @default("python")
  stdout     String?
  stderr     String?
  status     String   // "passed", "failed", "error", "pending"
  score      Int?     // 0-100
  testResults String? // JSON array of individual test results
  aiReview   String?  // AI-generated code review (Markdown)
  timeTaken  Int?     // seconds spent coding
  createdAt  DateTime @default(now())

  userId     String
  exerciseId String?  // Now stores the static exercise ID (slug)
  projectId  String?  // Now stores the static project ID (slug)

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// ENGINE 10: PROGRESS & GAMIFICATION
// ============================================================

model Progress {
  id          String   @id @default(cuid())
  status      String   @default("not_started") // not_started, in_progress, completed
  score       Int?
  completedAt DateTime?
  timeSpent   Int      @default(0) // total seconds
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId   String
  lessonId String // Now stores the static lesson ID (slug)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model QuizSubmission {
  id          String   @id @default(cuid())
  score       Int
  total       Int
  completedAt DateTime @default(now())

  userId      String
  quizId      String // Now stores the static quiz ID (slug)

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quizId])
}

model Streak {
  id        String   @id @default(cuid())
  date      DateTime // The specific day
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ============================================================
// ENGINE 14: ACHIEVEMENTS
// ============================================================

model Achievement {
  id          String @id @default(cuid())
  title       String @unique
  description String
  icon        String // Lucide icon name
  color       String // Tailwind color class
  xpReward    Int    @default(100)
  condition   String // JSON describing the unlock condition

  users UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  unlockedAt    DateTime @default(now())

  userId        String
  achievementId String

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

// ============================================================
// ENGINE 15: NOTES & BOOKMARKS
// ============================================================

model Note {
  id        String   @id @default(cuid())
  content   String
  module    String?  // Which module this note is related to
  lessonRef String?  // Optional reference to a static lesson ID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id        String   @id @default(cuid())
  title     String
  type      String   // "lesson", "exercise", "quiz", "project"
  targetId  String   // The ID of the bookmarked static item
  module    String?
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetId])
}

// ============================================================
// ENGINE 7: AI MENTOR
// ============================================================

model AIChat {
  id        String   @id @default(cuid())
  title     String?
  context   String?  // JSON: { lessonId, topicId, moduleId }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId   String
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AIChatMessage[]
}

model AIChatMessage {
  id        String   @id @default(cuid())
  role      String   // "user", "assistant", "system"
  content   String
  code      String?  // Optional code context
  createdAt DateTime @default(now())

  chatId String
  chat   AIChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

// ============================================================
// ENGINE 16: MEMORY
// ============================================================

model UserMemory {
  id        String   @id @default(cuid())
  key       String   // "weak_topics", "common_mistakes", "explanation_style"
  value     String   // JSON value
  updatedAt DateTime @updatedAt

  userId String

  @@unique([userId, key])
}
