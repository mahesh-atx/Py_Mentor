// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ============================================================
// ENGINE 1: AUTHENTICATION
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  progress      Progress[]
  submissions   Submission[]
  achievements  UserAchievement[]
  notes         Note[]
  bookmarks     Bookmark[]
  aiChats       AIChat[]
  streaks       Streak[]
  sessions      Session[]
  accounts      Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// ENGINE 2: CURRICULUM
// ============================================================

model Roadmap {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  language    String   // "python", "javascript", etc.
  icon        String?
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  modules Module[]
}

model Module {
  id          String   @id @default(cuid())
  title       String
  slug        String
  description String
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  roadmapId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roadmap Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  topics  Topic[]

  @@unique([roadmapId, slug])
}

model Topic {
  id          String   @id @default(cuid())
  title       String
  slug        String
  description String
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  moduleId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  module    Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lessons   Lesson[]
  exercises Exercise[]
  quizzes   Quiz[]
  projects  Project[]

  @@unique([moduleId, slug])
}

// ============================================================
// ENGINE 4: LESSON ENGINE
// ============================================================

model Lesson {
  id          String   @id @default(cuid())
  title       String
  slug        String
  content     String   // Markdown or JSON content
  objectives  String?  // JSON array of learning objectives
  examples    String?  // JSON array of code examples
  diagrams    String?  // JSON array of diagram URLs or SVG data
  order       Int      @default(0)
  difficulty  String   @default("beginner") // beginner, intermediate, advanced
  xpReward    Int      @default(50)
  isPublished Boolean  @default(false)
  isGenerated Boolean  @default(false) // true if AI-generated
  topicId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topic    Topic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  progress Progress[]

  @@unique([topicId, slug])
}

// ============================================================
// ENGINE 8: PRACTICE
// ============================================================

model Exercise {
  id           String   @id @default(cuid())
  title        String
  slug         String
  description  String   // Problem statement (Markdown)
  starterCode  String?  // Initial code in the editor
  solutionCode String?  // Reference solution
  hints        String?  // JSON array of progressive hints
  testCases    String   // JSON array of { input, expectedOutput }
  difficulty   String   @default("easy") // easy, medium, hard
  xpReward     Int      @default(100)
  timeLimit    Int      @default(10) // seconds
  order        Int      @default(0)
  isPublished  Boolean  @default(false)
  isGenerated  Boolean  @default(false)
  topicId      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  topic       Topic        @relation(fields: [topicId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@unique([topicId, slug])
}

// ============================================================
// ENGINE 11: QUIZ
// ============================================================

model Quiz {
  id          String   @id @default(cuid())
  title       String
  slug        String
  description String?
  xpReward    Int      @default(100)
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  isGenerated Boolean  @default(false)
  topicId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topic     Topic          @relation(fields: [topicId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]

  @@unique([topicId, slug])
}

model QuizQuestion {
  id           String @id @default(cuid())
  type         String // "mcq", "output_prediction", "debugging", "fill_blank", "coding"
  question     String
  options      String? // JSON array for MCQ options
  correctAnswer String
  explanation  String?
  code         String? // Code snippet for output_prediction / debugging
  difficulty   String @default("medium")
  order        Int    @default(0)
  quizId       String

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

// ============================================================
// ENGINE 12: PROJECTS
// ============================================================

model Project {
  id           String   @id @default(cuid())
  title        String
  slug         String
  description  String
  requirements String   // JSON array of requirement strings
  milestones   String?  // JSON array of milestone objects
  hints        String?  // JSON array of AI guidance hints
  testCases    String?  // JSON array of test cases
  difficulty   String   @default("medium")
  estimatedTime String? // "2 Hours", "4 Hours"
  xpReward     Int      @default(500)
  skills       String?  // JSON array of skills e.g. ["Variables", "Functions"]
  icon         String?
  order        Int      @default(0)
  isPublished  Boolean  @default(false)
  isGenerated  Boolean  @default(false)
  topicId      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  topic       Topic        @relation(fields: [topicId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@unique([topicId, slug])
}

// ============================================================
// ENGINE 6: SUBMISSIONS
// ============================================================

model Submission {
  id         String   @id @default(cuid())
  code       String
  language   String   @default("python")
  stdout     String?
  stderr     String?
  status     String   // "passed", "failed", "error", "pending"
  score      Int?     // 0-100
  testResults String? // JSON array of individual test results
  aiReview   String?  // AI-generated code review (Markdown)
  timeTaken  Int?     // seconds spent coding
  createdAt  DateTime @default(now())

  userId     String
  exerciseId String?
  projectId  String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise? @relation(fields: [exerciseId], references: [id], onDelete: SetNull)
  project  Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

// ============================================================
// ENGINE 10: PROGRESS & GAMIFICATION
// ============================================================

model Progress {
  id          String   @id @default(cuid())
  status      String   @default("not_started") // not_started, in_progress, completed
  score       Int?
  completedAt DateTime?
  timeSpent   Int      @default(0) // total seconds
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId   String
  lessonId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Streak {
  id        String   @id @default(cuid())
  date      DateTime // The specific day
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ============================================================
// ENGINE 14: ACHIEVEMENTS
// ============================================================

model Achievement {
  id          String @id @default(cuid())
  title       String @unique
  description String
  icon        String // Lucide icon name
  color       String // Tailwind color class
  xpReward    Int    @default(100)
  condition   String // JSON describing the unlock condition

  users UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  unlockedAt    DateTime @default(now())

  userId        String
  achievementId String

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

// ============================================================
// ENGINE 15: NOTES & BOOKMARKS
// ============================================================

model Note {
  id        String   @id @default(cuid())
  content   String
  module    String?  // Which module this note is related to
  lessonRef String?  // Optional reference to a lesson ID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id        String   @id @default(cuid())
  title     String
  type      String   // "lesson", "exercise", "quiz", "project"
  targetId  String   // The ID of the bookmarked item
  module    String?
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetId])
}

// ============================================================
// ENGINE 7: AI MENTOR
// ============================================================

model AIChat {
  id        String   @id @default(cuid())
  title     String?
  context   String?  // JSON: { lessonId, topicId, moduleId }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId   String
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AIChatMessage[]
}

model AIChatMessage {
  id        String   @id @default(cuid())
  role      String   // "user", "assistant", "system"
  content   String
  code      String?  // Optional code context
  createdAt DateTime @default(now())

  chatId String
  chat   AIChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

// ============================================================
// ENGINE 16: MEMORY
// ============================================================

model UserMemory {
  id        String   @id @default(cuid())
  key       String   // "weak_topics", "common_mistakes", "explanation_style"
  value     String   // JSON value
  updatedAt DateTime @updatedAt

  userId String

  @@unique([userId, key])
}
